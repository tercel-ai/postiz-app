# Extension build profile: DEV (the *-dev.aisee.live cloud stack).
# Used by: npm run pack-ext:dev  (→ scripts/pack.sh dev)
#
# Only the 5 vars the extension build consumes (vite envPrefix). No secrets —
# safe to commit. EXTENSION_ENV is intentionally unset so the dev hosts stay in
# host_permissions (EXTENSION_ENV=production would strip them).
FRONTEND_URL=https://app-dev.aisee.live
NEXT_PUBLIC_BACKEND_URL=https://api-post-dev.aisee.live
AUTH_URL=https://api-auth-dev.aisee.live
LOGIN_URL=https://app-dev.aisee.live/sign-in
ENGAGE_X_ENABLED=true
