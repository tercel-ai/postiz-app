# Extension build profile: LOCAL (the LAN dev stack on this machine).
# Used by: npm run pack-ext:local  (→ scripts/pack.sh local)
#
# Only the 5 vars the extension build consumes (vite envPrefix). No secrets —
# safe to commit. The frontend/backend/auth hosts must move together as a set so
# login (FRONTEND/AUTH) and the scan/metrics executor (BACKEND) agree.
#
# 192.168.110.98 is this dev machine's LAN IP (already whitelisted in
# vite.config.base.ts). FRONTEND_URL drives both host_permissions and the
# auth-bridge content script, so set it to the origin you actually open.
FRONTEND_URL=http://192.168.110.98:3001
NEXT_PUBLIC_BACKEND_URL=http://192.168.110.98:3000
AUTH_URL=http://192.168.110.98:9001
LOGIN_URL=http://192.168.110.98:3001/sign-in
ENGAGE_X_ENABLED=true
