# Extension build profile: PROD (the public *.aisee.live stack — store release).
# Used by: npm run pack-ext:prod  (→ scripts/pack.sh prod)
#
# Only the vars the extension build consumes (vite envPrefix). No secrets — safe
# to commit. EXTENSION_ENV=production ships ONLY production origins in
# host_permissions (no localhost/LAN/dev) and strips console.debug.
EXTENSION_ENV=production
FRONTEND_URL=https://app.aisee.live
NEXT_PUBLIC_BACKEND_URL=https://api-post.aisee.live
AUTH_URL=https://api-auth.aisee.live
LOGIN_URL=https://app.aisee.live/sign-in
