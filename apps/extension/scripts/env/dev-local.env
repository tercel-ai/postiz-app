# Extension build profile: DEV-LOCAL (dev cloud API + frontend on this machine).
# Used by: npm run pack-ext:dev-local  (→ scripts/pack.sh dev-local)
#
# Same backend/auth stack as dev.env (*-dev.aisee.live), but the frontend is a
# local dev server at localhost:3000. FRONTEND_URL drives both host_permissions
# and the auth-bridge content script (frontendMatch in vite.config.base.ts), so
# no vite config change is needed. EXTENSION_ENV stays unset so localhost/dev
# hosts remain in host_permissions.
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=https://api-post-dev.aisee.live
AUTH_URL=https://api-auth-dev.aisee.live
LOGIN_URL=http://localhost:3000/sign-in
ENGAGE_X_ENABLED=true
