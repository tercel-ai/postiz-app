model EngageConfig {
  id             String    @id @default(uuid())
  organizationId String    @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enabled        Boolean   @default(false)
  lastScanAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  keywords          EngageKeyword[]
  monitoredChannels EngageMonitoredChannel[]
  trackedAccounts   EngageTrackedAccount[]
  xReplyAccounts    EngageXReplyAccount[]
}

model EngageKeyword {
  id             String    @id @default(uuid())
  configId       String
  config         EngageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  organizationId String
  keyword        String
  type           String?
  enabled        Boolean   @default(true)
  weeklyHitCount Int       @default(0)
  totalHitCount  Int       @default(0)
  lastCountedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  initialScans EngageKeywordInitialScan[]

  @@unique([configId, keyword])
  @@index([organizationId])
  @@index([configId, enabled])
}

model EngageKeywordInitialScan {
  id             String    @id @default(uuid())
  organizationId String
  keywordId      String
  keywordRef     EngageKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  platform       String
  keyword        String
  status         String    @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  startedAt      DateTime?
  completedAt    DateTime?
  error          String?
  attempts       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([keywordId, platform])
  @@index([status, platform, createdAt])
  @@index([organizationId, platform])
}

model EngageMonitoredChannel {
  id             String    @id @default(uuid())
  configId       String
  config         EngageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  organizationId String
  platform       String
  channelId      String
  channelName    String
  audienceSize   Int       @default(0)
  enabled        Boolean   @default(true)
  lastScannedAt  DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([configId, platform, channelId])
  @@index([organizationId])
  @@index([configId, platform, enabled])
}

model EngageTrackedAccount {
  id             String    @id @default(uuid())
  configId       String
  config         EngageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  organizationId String
  platform       String    @default("x")
  username       String
  displayName    String?
  picture        String?
  categoryLabel  String?
  enabled        Boolean   @default(true)
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([configId, platform, username])
  @@index([organizationId, enabled])
}

model EngageXReplyAccount {
  id                  String    @id @default(uuid())
  configId            String
  config              EngageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  organizationId      String
  integrationId       String    @unique
  integration         Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  engageEnabled       Boolean   @default(true)
  autoReplyEnabled    Boolean   @default(false)
  autoReplyTimeStart  String?
  autoReplyTimeEnd    String?
  autoReplyTimezone   String?
  defaultStrategy     String    @default("EXPERT_ANSWER")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([configId, integrationId])
  @@index([organizationId, engageEnabled])
}

// Global post table — one row per (platform, externalPostId), shared across all
// orgs. Holds immutable content + objective metrics/scores. Per-org mutable state
// (status, bookmark, keyword/tracked scores) lives in EngageOpportunityState.
model EngageOpportunity {
  id               String    @id @default(uuid())
  platform         String
  externalPostId   String
  externalPostUrl  String
  channelId        String?
  channelName      String?
  // Community/channel audience size (e.g. Reddit subreddit_subscribers). Drives
  // scoreAuthority on community platforms. Null on platforms without a channel (X).
  channelFollowers Int?
  authorUsername   String
  authorDisplayName String?
  // Post author's real follower count (X). Null on platforms where it isn't
  // collected (Reddit — authority uses channelFollowers instead).
  authorFollowers  Int?
  authorAvatarUrl  String?
  postContent      String
  postPublishedAt  DateTime

  // Objective scores — identical for every org viewing this post.
  scoreHeat        Int       @default(0)
  scoreAuthority   Int       @default(0)
  scoreRecency     Int       @default(0)

  intentTags       String[]
  primaryIntent    String    @default("discussion")
  intentScore      Float?

  metricLikes      Int       @default(0)
  metricReplies    Int       @default(0)
  metricRetweets   Int       @default(0)
  metricQuotes     Int       @default(0)
  metricBookmarks  Int       @default(0)
  metricViews      Int       @default(0)
  metricShares     Int       @default(0)
  metricSaves      Int       @default(0)
  metricScore      Int       @default(0)
  metricUpvoteRatio Float?
  metricComments   Int       @default(0)

  rawData          Json?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  states           EngageOpportunityState[]
  sentReplies      EngageSentReply[]

  @@unique([platform, externalPostId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([postPublishedAt])
  // GIN index for intentTags @> ARRAY[...] (Prisma: { has: tag }).
  @@index([intentTags], type: Gin)
  // Trigram index on postContent for keyword ILIKE previews (getKeywordPosts).
  // `db push` cannot create a pg_trgm/gin_trgm_ops index, so it is created by
  // ./engage-indexes.sql, run automatically after push via the "prisma-db-push"
  // npm script (which chains "prisma-db-indexes").
}

enum EngageOpportunityStatus {
  NEW
  DISMISSED
  REPLIED
  SCHEDULED
  AUTO_QUEUED
  EXPIRED
}

// Per-org mutable state for a global opportunity. Created at scan time when a
// post matches the org's keywords. Total `score` = scoreKeyword + scoreTracked +
// opportunity.(scoreHeat + scoreAuthority + scoreRecency); recomputed each scan.
model EngageOpportunityState {
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunityId  String
  opportunity    EngageOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  status         EngageOpportunityStatus @default(NEW)
  bookmarked     Boolean   @default(false)

  score          Int       @default(0)
  scoreKeyword   Int       @default(0)
  scoreTracked   Int       @default(0)

  // The org's enabled keywords this post matched at scan time (text, as
  // configured). Per-org — strictly within this org's keyword scope — so it
  // lives here, alongside scoreKeyword, not on the shared EngageOpportunity
  // (whose union of all orgs' keywords would leak words outside this org's set).
  // Refreshed on every re-scan to track keyword edits.
  matchedKeywords String[]

  // Append-only audit log of every AI reply draft this org generated for this
  // opportunity. Each successful generation pushes one entry (content + input
  // params + the credits charged + the BillingRecord.taskId it links to), so a
  // user who regenerates several times keeps every version. Per-org because both
  // the content and its billing are org-scoped. Never truncated — reply versions
  // are few per opportunity. Shape: GenerationHistoryEntry[] (engage.repository.ts).
  generationHistory Json?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@id([organizationId, opportunityId])
  @@index([organizationId, status])
  @@index([organizationId, score])
  @@index([organizationId, bookmarked])
  @@index([opportunityId])
}

model EngageSentReply {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  opportunityId  String
  opportunity    EngageOpportunity @relation(fields: [opportunityId], references: [id])

  postId         String    @unique
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  inputData      Json
  authorReplied  Boolean   @default(false)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // An org may reply to the same opportunity more than once (e.g. a batch send
  // from several of its accounts), so tracking is keyed per-post (postId @unique)
  // rather than per-opportunity. The composite index keeps the per-opportunity
  // reads (getOpportunityDetail / getSentReplyByOpportunity) fast.
  @@index([organizationId])
  @@index([organizationId, opportunityId])
}

// Global, org-independent cursor for one scan unit. A "scan unit" is a single
// upstream fetch: a keyword search, a tracked-account search, or a monitored-
// channel search. Shared across all orgs (the same keyword/account/channel is
// fetched once, then fanned out) — so this table is keyed by the unit, never by
// org. Drives incremental fetching (lastSeen*) and adaptive scheduling
// (lastScanStartedAt + env cadence → next due; cooldownUntil for rate-limit
// back-off). See docs/engage/.
model EngageScanCursor {
  id                 String    @id @default(uuid())

  // ── Identity: one row per scan unit ──
  platform           String    // 'x' | 'reddit' | ...
  scanType           String    // 'keyword' | 'tracked' | 'channel'
  // keyword text (keyword) | username (tracked) | subreddit id (channel).
  // For scoped scans the org's keywords are OR-batched into the query at scan
  // time, so the keyword is NOT part of identity — one fetch per scope.
  scanKey            String

  // ── Incremental cursor (where the last fetch stopped) ──
  lastSeenExternalId String?   // X since_id / Reddit fullname of newest seen post
  lastSeenAt         DateTime? // newest seen post's publish time (Reddit stop cond.)

  // ── Scheduling (next due is DERIVED: lastScanStartedAt + env cadence) ──
  lastScanStartedAt  DateTime? // when the most recent scan began (anchors next due)
  lastScannedAt      DateTime? // when the most recent scan completed (display only)
  cooldownUntil      DateTime? // rate-limit back-off; null when not cooling down
  status             String    @default("IDLE") // IDLE | SCANNING (single-flight)
  // Per-claim secret handed to the extension as its task handle. Rotates on
  // every claim and is cleared on complete/release, so a leaked/old token cannot
  // complete a lease it no longer owns (session binding for the async path).
  leaseToken         String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([platform, scanType, scanKey])
  @@index([status, scanType, lastScanStartedAt])
  @@index([leaseToken])
}

model EngageDataTicks {
  organizationId String
  platform       String
  type           String
  timeUnit       String
  statisticsTime DateTime
  value          BigInt    @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, platform, type, timeUnit, statisticsTime])
  @@index([organizationId, platform, type, timeUnit])
  @@index([organizationId, type, statisticsTime])
}

// Internal API-usage / cost telemetry (NOT user-facing). One row per
// (day, platform, category): a running per-day counter incremented via atomic
// upsert. `quantity` is RECORDS for read categories (X bills per returned
// resource) or REQUESTS for write categories (X bills per request) — which one
// is implied by the category (see api-usage.service price map). Prices live in
// code/Settings, never in this table, so cost = SUM(quantity) * price computed
// at report time and re-priceable without backfill. Deliberately global (no org
// / integration) to keep cardinality tiny (~platforms * categories rows/day).
model ApiUsageTick {
  date      DateTime // day bucket (UTC midnight)
  platform  String // 'x' | 'reddit' | ...
  category  String // platform-scoped billing category
  quantity  BigInt   @default(0)
  updatedAt DateTime @updatedAt

  @@unique([date, platform, category])
  @@index([date])
}

// Business-semantic API-usage telemetry. Complements ApiUsageTick (X official
// billing granularity) by re-classifying the SAME recorded units under a
// business purpose (bizCategory: post_publish / engage_reply / engage_scan /
// post_metrics / engage_metrics / user_lookup / ...) and the owning org.
// Populated automatically: recordApiUsage also writes a row here whenever a
// business context is active (runWithBizUsage wraps the business entry points,
// so every nested X/Reddit call inherits the purpose). Keeps the X billing
// `category` alongside `bizCategory` so cost = SUM(quantity) * priceFor(platform,
// category) stays computable PER business purpose. organizationId '' means
// "no org / system-level job" (kept non-null so upserts merge — Prisma treats
// NULLs as distinct in unique keys).
model ApiBizUsageTick {
  date           DateTime // day bucket (UTC midnight)
  organizationId String // '' = system / no org
  platform       String // 'x' | 'reddit' | ...
  bizCategory    String // business purpose of the call
  category       String // X billing category (mirrors ApiUsageTick.category)
  quantity       BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([date, organizationId, platform, bizCategory, category])
  @@index([date])
  @@index([organizationId, date])
}

// Engage opportunity score distribution, per org/platform/day. `phase`
// separates 'scanned' (every keyword-matched scored post, BEFORE the
// ENGAGE_MIN_SCORE gate) from 'persisted' (the subset actually stored as
// opportunities, score >= ENGAGE_MIN_SCORE). `bucket` is a fixed,
// non-overlapping score band: '0-50' | '50-60' | '60-70' | '70-85' | '85-100'
// (the top band is a catch-all that also covers 101-105, the scorer's true
// max). Lets us report how many valid posts each quality tier yields without
// scanning Post/EngageOpportunity rows.
model EngageScoreTick {
  date           DateTime // day bucket (UTC midnight)
  organizationId String
  platform       String // 'x' | 'reddit' | ...
  phase          String // 'scanned' | 'persisted'
  bucket         String // score band (non-overlapping)
  quantity       BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([date, organizationId, platform, phase, bucket])
  @@index([date])
  @@index([organizationId, date])
}
